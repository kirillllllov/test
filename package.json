  "bugs": {
    "url": "https://github.com/ZeneZ0/Support_Bot_IST/issues"
  },
  "homepage": "https://github.com/ZeneZ0/Support_Bot_IST#readme",
  "packageManager": "yarn@1.22.22"
}
