{
  "name": "support_bot_ist",
  "version": "1.0.0",
  "description": "Репозиторий для проекта Бот Поддержки",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json && shx cp package.json yarn.lock dist/",
    "start": "node src/index.ts",
    "dev": "tsx watch src/index.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "docker:build": "docker build -f Dockerfile.prod -t support_bot .",
    "deploy:swarm": "echo 'Deploy to swarm...'"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.922.0",
    "@aws-sdk/client-s3": "^3.937.0",
    "@aws-sdk/lib-dynamodb": "^3.922.0",
    "@paralleldrive/cuid2": "^3.1.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.6",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2",
    "serverless-http": "^4.0.0",
    "xstate": "^5.23.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.9.1",
    "@types/supertest": "^6.0.3",
    "@vitest/eslint-plugin": "^1.3.24",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^61.0.2",
    "eslint-plugin-vitest": "^0.5.4",
    "prettier": "^3.6.2",
    "shx": "^0.4.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZeneZ0/Support_Bot_IST.git"
  },
  "keywords": [
    "bot",
    "support",
    "xstate",
    "express",
    "typescript",
    "dynamodb",
    "minio",
    "s3",
    "storage"
  ],
